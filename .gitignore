# macOS
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride
Icon?

# Swift Package Manager
.build/
.swiftpm/
# Package.resolved IS committed — this is an app, so pin exact dependency versions.

# Xcode
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
DerivedData/
*.xcuserstate
*.moved-aside

# App bundle (built artifact, regenerated by the bundling script)
Contained.app/

# Release artifacts (DMGs + the Sparkle staging dir). docs/appcast.xml IS committed (Pages-served).
*.dmg
/updates/

# Captured CLI fixtures used only for local schema grounding (top-level only;
# the committed test resources live under Tests/ContainedCoreTests/Fixtures).
/Fixtures/

# Signing & secrets — NEVER commit these (signing happens locally / via CI secrets).
*.p12
*.cer
*.certSigningRequest
*.mobileprovision
*.provisionprofile
*.pem
*.key
*_private_key*
.env
.env.*
*.local
.netrc
AuthKey_*.p8

