# macOS
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride
Icon?

# Swift Package Manager
.build/
.swiftpm/
# Package.resolved IS committed — this is an app, so pin exact dependency versions.

# Xcode
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
DerivedData/
*.xcuserstate
*.moved-aside

# App bundle (built artifact, regenerated by the bundling script)
Contained.app/

# Release artifacts (DMGs + Sparkle/release-note staging). Root appcast.xml IS committed on
# release branches, but workflow path filters ignore appcast-only commits to avoid CI loops.
*.dmg
/updates/
/.release/
/.release-notes/

# Change fragments are intended to be committed when used:
#   changes/unreleased/*.md
#   changes/nightly/*.md
#   changes/beta/*.md

# Captured CLI fixtures used only for local schema grounding (top-level only;
# the committed test resources live under Tests/ContainedCoreTests/Fixtures).
/Fixtures/

# Signing & secrets — NEVER commit these (signing happens locally / via CI secrets).
*.p12
*.cer
*.certSigningRequest
*.mobileprovision
*.provisionprofile
*.pem
*.key
*_private_key*
.env
.env.*
*.local
.netrc
AuthKey_*.p8

# Editor noise
*.swp
*~
.vscode/
.idea/
.zed/
